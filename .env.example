DJANGO_SETTINGS_MODULE=i3aps_platform.settings.prod
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret-before-deploy
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,seu-dominio.gov.br
DJANGO_CSRF_TRUSTED_ORIGINS=https://seu-dominio.gov.br

# Use false for local Docker testing over http://127.0.0.1:8080.
# In online production behind HTTPS, set these values to true.
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0

POSTGRES_DB=i3aps
POSTGRES_USER=i3aps
POSTGRES_PASSWORD=i3aps
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
